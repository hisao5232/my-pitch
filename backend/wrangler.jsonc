{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "pitch-backend",
	"main": "src/index.ts",
	"compatibility_date": "2026-05-03",
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "my-pitch-db",
			"database_id": "42099248-d7fe-4880-840f-206f99b776ca"
		}
	],
    "triggers": {
        "crons": [
            "30 20 * * *" // UTC 20:30 = JST 05:30
        ]
    }
}
